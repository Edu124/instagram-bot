# ── CodeForge Instagram Bot — Environment Variables ──────────────────────────

# Server
PORT=3000
SERVER_URL=https://your-server.com    # Your public server URL (for Razorpay callback)
SUCCESS_URL=https://your-server.com/thanks

# ManyChat
MANYCHAT_API_KEY=your_manychat_api_key_here

# Razorpay (for payment links)
RAZORPAY_KEY_ID=rzp_live_xxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret

# CodeForge AI Hub (local LLM)
HUB_URL=ws://127.0.0.1:7471

# Business Details (for invoices)
BUSINESS_NAME=Your Store Name
BUSINESS_GST=GSTXXXXXXXXXXXXXXX
BUSINESS_ADDRESS=Your Business Address, City, State, PIN
